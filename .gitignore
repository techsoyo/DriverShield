# ============================================================
# .gitignore — DriverShield Android Project
# Generado: 2026-04-16
# ============================================================

# ── Gradle ──────────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ── Módulos de build ────────────────────────────────────────
/app/build/
/captures/

# ── Android Studio / IntelliJ ───────────────────────────────
*.iml
.idea/
local.properties

# ── Artefactos compilados ───────────────────────────────────
*.apk
*.aab
*.ap_
*.dex

# ── Compilador Kotlin ───────────────────────────────────────
.kotlin/

# ── NDK / CMake ─────────────────────────────────────────────
.externalNativeBuild/
.cxx/

# ── Seguridad y secretos (CRÍTICO — nunca versionar) ────────
*.jks
*.keystore
*.p12
google-services.json

# ── SQLite / Room (ficheros runtime, no schemas) ─────────────
*.db
*.db-shm
*.db-wal

# ── Logs y volcados ─────────────────────────────────────────
*.log
*.hprof
compile_log.txt
ksp_log.txt

# ── Notas personales / docs de trabajo ──────────────────────
# docs/ se trackea — contiene documentación técnica del proyecto

# ── macOS ───────────────────────────────────────────────────
.DS_Store